 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<style>\n  @page { margin: 12mm 14mm 8mm 14mm; }\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #1a1a2e; background: #fff; }\n  .page { max-width: 820px; margin: 0 auto; padding: 0; }\n  .hotel-logo { max-height: 70px; max-width: 140px; }\n  .logo-box { display: inline-block; width: 46px; height: 46px; background: #1a1a2e; color: #fff; font-size: 16pt; font-weight: 700; text-align: center; line-height: 46px; border-radius: 5px; }\n  .hotel-name { font-size: 14pt; font-weight: 700; color: #1a1a2e; }\n  .hotel-sub { font-size: 7.5pt; color: #6b7280; margin-top: 2px; line-height: 1.5; }\n  .doc-title { font-size: 13pt; font-weight: 700; color: #1a1a2e; }\n  .doc-subtitle { font-size: 7pt; color: #6b7280; text-transform: uppercase; letter-spacing: 0.8px; margin-top: 2px; }\n  .doc-ref { font-size: 8pt; color: #6b7280; margin-top: 6px; line-height: 1.7; }\n  .doc-ref strong { color: #374151; }\n  .header-divider { border: none; border-top: 2px solid #1a1a2e; margin: 14px 0 16px; }\n  .section-title { font-size: 7.5pt; font-weight: 700; color: #1a1a2e; text-transform: uppercase; letter-spacing: 0.6px; background: #f1f3f8; border-left: 3px solid #1a1a2e; border-bottom: 1px solid #d1d5db; padding: 5px 9px; margin-top: 14px; margin-bottom: 8px; }\n  .info-table { width: 100%; border-collapse: collapse; margin-bottom: 4px; }\n  .info-table td { padding: 4px 8px; font-size: 9pt; border-bottom: 1px solid #f1f5f9; vertical-align: middle; white-space: nowrap; }\n  .info-table tr:last-child td { border-bottom: none; }\n  .info-key { width: 22%; color: #1a1a2e; font-weight: 700; }\n  .info-val { width: 28%; color: #1a1a2e; font-weight: 400; }\n  .data-table { width: 100%; border-collapse: collapse; font-size: 8pt; margin-bottom: 4px; }\n  .data-table thead tr { background: #f1f3f8; color: #1a1a2e; border-bottom: 2px solid #1a1a2e; }\n  .data-table thead th { padding: 6px 7px; text-align: left; font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; }\n  .data-table thead th.num { text-align: right; }\n  .data-table tbody tr:nth-child(even) { background: #f9fafb; }\n  .data-table tbody td { padding: 6px 7px; border-bottom: 1px solid #f1f5f9; color: #374151; }\n  .data-table tbody td.num { text-align: right; }\n  .data-table tfoot tr { border-top: 2px solid #1a1a2e; background: #f9fafb; }\n  .data-table tfoot td { padding: 7px 7px; font-weight: 700; color: #1a1a2e; }\n  .data-table tfoot td.num { text-align: right; }\n  .footer-divider { border: none; border-top: 1px solid #e5e7eb; margin: 20px 0 12px; }\n  .footer-note { font-size: 7pt; color: #9ca3af; line-height: 1.7; }\n  .footer-company { font-size: 9pt; font-weight: 700; color: #1a1a2e; }\n  .footer-date { font-size: 7pt; color: #9ca3af; margin-top: 2px; }\n  .sig-line { margin-top: 16px; border-top: 1px solid #e5e7eb; padding-top: 5px; font-size: 7pt; color: #9ca3af; text-align: center; }\n</style>\n</head>\n<body>\n<div class=\"page\">\n\n  <!-- HEADER -->\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n    <tr>\n      <td width=\"55%\" valign=\"top\">\n        <table cellpadding=\"0\" cellspacing=\"0\">\n          <tr>\n            <td style=\"padding-right:10px;\" valign=\"middle\">\n              {% if hotel_logo %}<img src=\"{{ hotel_logo }}\" alt=\"{{ company }}\" class=\"hotel-logo\" />\n              {% else %}<div class=\"logo-box\">{{ (company or 'H')[:1] }}</div>{% endif %}\n            </td>\n            <td valign=\"middle\">\n              <div class=\"hotel-name\">{{ company }}</div>\n              <div class=\"hotel-sub\">\n                {% if hotel_tagline %}{{ hotel_tagline }}<br>{% endif %}\n                {% if hotel_address %}{{ hotel_address }}<br>{% endif %}\n                {% if hotel_phone %}{{ hotel_phone }}{% if hotel_email %} &middot; {% endif %}{% endif %}\n                {% if hotel_email %}{{ hotel_email }}{% endif %}\n              </div>\n            </td>\n          </tr>\n        </table>\n      </td>\n      <td valign=\"top\" align=\"right\">\n        <div class=\"doc-title\">Complimentary &amp; House Use</div>\n        <div class=\"doc-subtitle\">Special Reservation Report</div>\n        <div class=\"doc-ref\">\n          <strong>Period:</strong> {{ filters.date_from }} &mdash; {{ filters.date_to }}<br>\n          <strong>Generated:</strong> {{ generated_at }}\n        </div>\n      </td>\n    </tr>\n  </table>\n  <hr class=\"header-divider\" />\n\n  <!-- FILTERS -->\n  <div class=\"section-title\">Report Filters</div>\n  <table class=\"info-table\" cellpadding=\"0\" cellspacing=\"0\">\n    <colgroup><col style=\"width:22%\" /><col style=\"width:28%\" /><col style=\"width:22%\" /><col style=\"width:28%\" /></colgroup>\n    <tr>\n      <td class=\"info-key\">Date From</td><td class=\"info-val\">{{ filters.date_from }}</td>\n      <td class=\"info-key\">Date To</td><td class=\"info-val\">{{ filters.date_to }}</td>\n    </tr>\n    <tr>\n      <td class=\"info-key\">Type</td><td class=\"info-val\">{{ filters.reservation_type or 'All Types' }}</td>\n      <td class=\"info-key\">Status</td><td class=\"info-val\">{{ filters.status or 'All' }}</td>\n    </tr>\n  </table>\n\n  <!-- RESERVATIONS TABLE -->\n  <div class=\"section-title\">Reservations &mdash; {{ rows | length }} record(s)</div>\n  {% if rows %}\n  <table class=\"data-table\" cellpadding=\"0\" cellspacing=\"0\">\n    <thead>\n      <tr>\n        <th>#</th><th>Reservation</th><th>Type</th><th>Guest</th>\n        <th>Check-In</th><th>Check-Out</th><th class=\"num\">Nights</th>\n        <th>Rooms</th><th>Status</th><th>Reason</th><th class=\"num\">Theoretical Rev</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for row in rows %}\n      <tr>\n        <td style=\"color:#9ca3af;\">{{ loop.index }}</td>\n        <td style=\"font-weight:600;font-size:7.5pt;\">{{ row.name }}</td>\n        <td style=\"color:#6b7280;\">{{ row.reservation_type }}</td>\n        <td>{{ row.primary_guest_name or '&mdash;' }}</td>\n        <td style=\"white-space:nowrap;\">{{ row.from_date }}</td>\n        <td style=\"white-space:nowrap;\">{{ row.to_date }}</td>\n        <td class=\"num\">{{ row.number_of_nights }}</td>\n        <td style=\"color:#6b7280;font-size:7.5pt;\">{{ row.room_numbers or '&mdash;' }}</td>\n        <td style=\"font-weight:600;color:{% if row.reservation_status == 'Confirmed' %}#15803d{% elif row.reservation_status == 'Cancelled' %}#dc2626{% else %}#374151{% endif %};\">\n          {{ row.reservation_status }}\n        </td>\n        <td style=\"color:#6b7280;font-size:7.5pt;\">{{ row.comp_reason or '&mdash;' }}</td>\n        <td class=\"num\">{% if row.theoretical_room_revenue %}&#x20a6;{{ \"{:,.0f}\".format(row.theoretical_room_revenue | float) }}{% else %}&mdash;{% endif %}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n    <tfoot>\n      <tr>\n        <td colspan=\"10\">Total Theoretical Revenue</td>\n        <td class=\"num\">&#x20a6;{{ \"{:,.2f}\".format(summary.theoretical_room_revenue | float) }}</td>\n      </tr>\n    </tfoot>\n  </table>\n  {% else %}\n  <p style=\"padding:14px;color:#9ca3af;font-size:8pt;border:1px dashed #e5e7eb;\">No records found for the selected filters.</p>\n  {% endif %}\n\n  <!-- SUMMARY -->\n  <div class=\"section-title\">Summary</div>\n  <table width=\"55%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-left:45%;\">\n    <tbody>\n      <tr>\n        <td style=\"padding:5px 10px;font-size:9pt;color:#6b7280;border-bottom:1px solid #f1f5f9;\">Total Reservations</td>\n        <td style=\"padding:5px 10px;font-size:9pt;text-align:right;font-weight:600;color:#1a1a2e;border-bottom:1px solid #f1f5f9;\">{{ summary.reservation_count }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding:5px 10px;font-size:9pt;color:#6b7280;border-bottom:1px solid #f1f5f9;\">House Use</td>\n        <td style=\"padding:5px 10px;font-size:9pt;text-align:right;font-weight:600;color:#1a1a2e;border-bottom:1px solid #f1f5f9;\">{{ summary.house_use_count }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding:5px 10px;font-size:9pt;color:#6b7280;border-bottom:1px solid #f1f5f9;\">Complimentary</td>\n        <td style=\"padding:5px 10px;font-size:9pt;text-align:right;font-weight:600;color:#1a1a2e;border-bottom:1px solid #f1f5f9;\">{{ summary.complimentary_count }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding:5px 10px;font-size:9pt;color:#6b7280;border-bottom:1px solid #f1f5f9;\">Total Room Nights</td>\n        <td style=\"padding:5px 10px;font-size:9pt;text-align:right;font-weight:600;color:#1a1a2e;border-bottom:1px solid #f1f5f9;\">{{ summary.room_nights | int }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding:5px 10px;font-size:9.5pt;font-weight:700;background:#f1f3f8;color:#1a1a2e;border-top:2px solid #1a1a2e;border-bottom:1px solid #d1d5db;\">Theoretical Revenue</td>\n        <td style=\"padding:5px 10px;font-size:9.5pt;text-align:right;font-weight:700;background:#f1f3f8;color:#1a1a2e;border-top:2px solid #1a1a2e;border-bottom:1px solid #d1d5db;\">&#x20a6;{{ \"{:,.2f}\".format(summary.theoretical_room_revenue | float) }}</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <!-- FOOTER -->\n  <hr class=\"footer-divider\" />\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n    <tr>\n      <td width=\"60%\" valign=\"bottom\">\n        <div class=\"footer-note\">\n          This report is generated by the {{ company }} Property Management System.<br>\n          <strong style=\"color:#374151;\">Period: {{ filters.date_from }} to {{ filters.date_to }}</strong>\n        </div>\n      </td>\n      <td valign=\"bottom\" align=\"right\">\n        <div class=\"footer-company\">{{ company }}</div>\n        <div class=\"footer-date\">{{ generated_at }}</div>\n        <div class=\"sig-line\">Authorised Signature</div>\n      </td>\n    </tr>\n  </table>\n</div>\n</body>\n</html>",
