 "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<style>\n  @page { margin: 12mm 14mm 8mm 14mm; }\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #1a1a2e; background: #fff; }\n  .page { max-width: 820px; margin: 0 auto; padding: 0; }\n  .hotel-logo { max-height: 70px; max-width: 140px; }\n  .logo-box { display: inline-block; width: 46px; height: 46px; background: #1a1a2e; color: #fff; font-size: 16pt; font-weight: 700; text-align: center; line-height: 46px; border-radius: 5px; }\n  .hotel-name { font-size: 14pt; font-weight: 700; color: #1a1a2e; }\n  .hotel-sub { font-size: 7.5pt; color: #6b7280; margin-top: 2px; line-height: 1.5; }\n  .doc-title { font-size: 13pt; font-weight: 700; color: #1a1a2e; }\n  .doc-subtitle { font-size: 7pt; color: #6b7280; text-transform: uppercase; letter-spacing: 0.8px; margin-top: 2px; }\n  .doc-ref { font-size: 8pt; color: #6b7280; margin-top: 6px; line-height: 1.7; }\n  .doc-ref strong { color: #374151; }\n  .header-divider { border: none; border-top: 2px solid #1a1a2e; margin: 14px 0 16px; }\n  .pill { display: inline-block; padding: 2px 9px; border-radius: 10px; font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; margin-right: 5px; border: 1px solid #d1d5db; background: #f9fafb; color: #374151; }\n  .pills-row { margin-bottom: 14px; }\n  .section-title { font-size: 7.5pt; font-weight: 700; color: #1a1a2e; text-transform: uppercase; letter-spacing: 0.6px; background: #f1f3f8; border-left: 3px solid #1a1a2e; border-bottom: 1px solid #d1d5db; padding: 5px 9px; margin-top: 14px; margin-bottom: 8px; }\n  .info-table { width: 100%; border-collapse: collapse; margin-bottom: 4px; }\n  .info-table td { padding: 4px 8px; font-size: 9pt; border-bottom: 1px solid #f1f5f9; vertical-align: middle; white-space: nowrap; }\n  .info-table tr:last-child td { border-bottom: none; }\n  .info-key { width: 22%; color: #1a1a2e; font-weight: 700; }\n  .info-val { width: 28%; color: #1a1a2e; font-weight: 400; }\n  .data-table { width: 100%; border-collapse: collapse; font-size: 8.5pt; margin-bottom: 4px; }\n  .data-table thead tr { background: #f1f3f8; color: #1a1a2e; border-bottom: 2px solid #1a1a2e; }\n  .data-table thead th { padding: 6px 9px; text-align: left; font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; }\n  .data-table thead th.num { text-align: right; }\n  .data-table tbody tr:nth-child(even) { background: #f9fafb; }\n  .data-table tbody td { padding: 7px 9px; border-bottom: 1px solid #f1f5f9; color: #374151; }\n  .data-table tbody td.num { text-align: right; }\n  .data-table tfoot tr { border-top: 2px solid #1a1a2e; background: #f9fafb; }\n  .data-table tfoot td { padding: 7px 9px; font-weight: 700; color: #1a1a2e; }\n  .data-table tfoot td.num { text-align: right; }\n  .balance-table { width: 55%; margin-left: 45%; border-collapse: collapse; margin-bottom: 4px; }\n  .balance-table td { padding: 6px 10px; font-size: 9pt; border-bottom: 1px solid #f1f5f9; }\n  .b-label { color: #6b7280; }\n  .b-value { text-align: right; font-weight: 600; color: #1a1a2e; }\n  .total-row td { background: #f1f3f8; color: #1a1a2e; font-weight: 700; font-size: 9.5pt; border-top: 2px solid #1a1a2e; border-bottom: 1px solid #d1d5db; }\n  .notice-box { border: 1px solid #e5e7eb; border-radius: 4px; padding: 10px 14px; font-size: 8pt; color: #374151; margin-top: 8px; background: #fffbeb; }\n  .footer-divider { border: none; border-top: 1px solid #e5e7eb; margin: 20px 0 12px; }\n  .footer-note { font-size: 7pt; color: #9ca3af; line-height: 1.7; }\n  .footer-company { font-size: 9pt; font-weight: 700; color: #1a1a2e; }\n  .footer-date { font-size: 7pt; color: #9ca3af; margin-top: 2px; }\n  .sig-line { margin-top: 16px; border-top: 1px solid #e5e7eb; padding-top: 5px; font-size: 7pt; color: #9ca3af; text-align: center; }\n</style>\n</head>\n<body>\n<div class=\"page\">\n\n  <!-- HEADER -->\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n    <tr>\n      <td width=\"55%\" valign=\"top\">\n        <table cellpadding=\"0\" cellspacing=\"0\">\n          <tr>\n            <td style=\"padding-right:10px;\" valign=\"middle\">\n              {% if hotel_logo %}\n                <img src=\"{{ hotel_logo }}\" alt=\"{{ company }}\" class=\"hotel-logo\" />\n              {% else %}\n                <div class=\"logo-box\">{{ (company or 'H')[:1] }}</div>\n              {% endif %}\n            </td>\n            <td valign=\"middle\">\n              <div class=\"hotel-name\">{{ company }}</div>\n              <div class=\"hotel-sub\">\n                {% if hotel_tagline %}{{ hotel_tagline }}<br>{% endif %}\n                {% if hotel_address %}{{ hotel_address }}<br>{% endif %}\n                {% if hotel_phone %}{{ hotel_phone }}{% if hotel_email %} &middot; {% endif %}{% endif %}\n                {% if hotel_email %}{{ hotel_email }}{% endif %}\n              </div>\n            </td>\n          </tr>\n        </table>\n      </td>\n      <td valign=\"top\" align=\"right\">\n        <div class=\"doc-title\">\n          {% if booking.docstatus == 0 %}Hall Booking Draft\n          {% elif booking.docstatus == 2 %}Hall Booking Cancelled\n          {% else %}Hall Booking Confirmation{% endif %}\n        </div>\n        <div class=\"doc-subtitle\">Event Booking Receipt</div>\n        <div class=\"doc-ref\">\n          <strong>Ref:</strong> {{ booking.name }}<br>\n          <strong>Generated:</strong> {{ generated_at }}\n        </div>\n      </td>\n    </tr>\n  </table>\n  <hr class=\"header-divider\" />\n\n  <!-- STATUS PILLS -->\n  <div class=\"pills-row\">\n    <span class=\"pill\">{{ booking.event_status or 'Scheduled' }}</span>\n    {% if booking.docstatus == 0 %}<span class=\"pill\">&#9679; Draft</span>{% endif %}\n    {% if booking.event_type %}<span class=\"pill\">{{ booking.event_type }}</span>{% endif %}\n  </div>\n\n  <!-- BOOKING DETAILS -->\n  <div class=\"section-title\">Booking Details</div>\n  <table class=\"info-table\" cellpadding=\"0\" cellspacing=\"0\">\n    <colgroup><col style=\"width:22%\" /><col style=\"width:28%\" /><col style=\"width:22%\" /><col style=\"width:28%\" /></colgroup>\n    <tr>\n      <td class=\"info-key\">Customer</td><td class=\"info-val\">{{ booking.customer_name or '&mdash;' }}</td>\n      <td class=\"info-key\">Mobile</td><td class=\"info-val\">{{ booking.mobile_number or '&mdash;' }}</td>\n    </tr>\n    <tr>\n      <td class=\"info-key\">Hall</td><td class=\"info-val\">{{ booking.hall or '&mdash;' }}</td>\n      <td class=\"info-key\">Event Type</td><td class=\"info-val\">{{ booking.event_type or '&mdash;' }}</td>\n    </tr>\n    <tr>\n      <td class=\"info-key\">Start</td><td class=\"info-val\">{{ booking.start_datetime }}</td>\n      <td class=\"info-key\">End</td><td class=\"info-val\">{{ booking.end_datetime }}</td>\n    </tr>\n    <tr>\n      <td class=\"info-key\">Duration</td><td class=\"info-val\">{{ booking.total_days | int }} day(s)</td>\n      <td class=\"info-key\">Rate / Day</td><td class=\"info-val\">&#x20a6;{{ \"{:,.2f}\".format(booking.rate | float) }}</td>\n    </tr>\n    {% if booking.sales_invoice %}\n    <tr>\n      <td class=\"info-key\">Sales Invoice</td><td class=\"info-val\" colspan=\"3\">{{ booking.sales_invoice }}</td>\n    </tr>\n    {% endif %}\n  </table>\n\n  <!-- HALL CHARGES -->\n  {% set hall_discount = 0 %}\n  {% if booking.discount_type == \"Percentage\" %}\n    {% set hall_discount = (booking.total_amount or 0) * ((booking.discount_amount or 0) / 100) %}\n  {% else %}\n    {% set hall_discount = booking.discount_amount or 0 %}\n  {% endif %}\n\n  <div class=\"section-title\">Hall Charges</div>\n  <table class=\"data-table\" cellpadding=\"0\" cellspacing=\"0\">\n    <thead>\n      <tr>\n        <th>Description</th><th class=\"num\">Days</th>\n        <th class=\"num\">Rate</th><th class=\"num\">Gross</th>\n        <th class=\"num\">Discount</th><th class=\"num\">Net</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td style=\"font-weight:600;\">{{ booking.hall or 'Hall Booking' }}</td>\n        <td class=\"num\">{{ booking.total_days | int }}</td>\n        <td class=\"num\">&#x20a6;{{ \"{:,.2f}\".format(booking.rate | float) }}</td>\n        <td class=\"num\">&#x20a6;{{ \"{:,.2f}\".format(booking.total_amount | float) }}</td>\n        <td class=\"num\">\n          &#x20a6;{{ \"{:,.2f}\".format(hall_discount | float) }}\n          {% if booking.discount_amount %}<br><span style=\"font-size:7pt;color:#6b7280;\">{{ booking.discount_type }}: {{ booking.discount_amount }}{% if booking.discount_type == \"Percentage\" %}%{% endif %}</span>{% endif %}\n        </td>\n        <td class=\"num\" style=\"font-weight:600;\">&#x20a6;{{ \"{:,.2f}\".format((booking.total_amount | float) - (hall_discount | float)) }}</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <!-- ADDITIONAL SERVICES -->\n  {% if additional_billings %}\n  <div class=\"section-title\">Additional Services</div>\n  <table class=\"data-table\" cellpadding=\"0\" cellspacing=\"0\">\n    <thead>\n      <tr>\n        <th>Service</th><th class=\"num\">Qty</th><th class=\"num\">Rate</th>\n        <th>Discount Type</th><th class=\"num\">Discount</th><th class=\"num\">Amount</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for row in additional_billings %}\n      <tr>\n        <td>{{ row.service or '&mdash;' }}</td>\n        <td class=\"num\">{{ row.qty or 0 }}</td>\n        <td class=\"num\">&#x20a6;{{ \"{:,.2f}\".format(row.rate | float) }}</td>\n        <td style=\"color:#6b7280;\">{{ row.discount_type or '&mdash;' }}</td>\n        <td class=\"num\">{% if row.discount_type == \"Percentage\" %}{{ row.discount_amount }}%{% else %}&#x20a6;{{ \"{:,.2f}\".format(row.discount_amount | float) }}{% endif %}</td>\n        <td class=\"num\" style=\"font-weight:600;\">&#x20a6;{{ \"{:,.2f}\".format(row.amount | float) }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n  {% endif %}\n\n  <!-- ADJUSTMENT HISTORY -->\n  {% if adjustment_history %}\n  <div class=\"section-title\">Adjustment History</div>\n  <table class=\"data-table\" cellpadding=\"0\" cellspacing=\"0\">\n    <thead>\n      <tr>\n        <th>Previous Period</th><th>New Period</th>\n        <th class=\"num\">Prev Days</th><th class=\"num\">New Days</th>\n        <th>Reason</th><th>Invoice</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for row in adjustment_history %}\n      <tr>\n        <td style=\"font-size:7.5pt;color:#6b7280;\">{{ row.previous_start }} &rarr; {{ row.previous_end }}</td>\n        <td style=\"font-size:7.5pt;color:#6b7280;\">{{ row.new_start }} &rarr; {{ row.new_end }}</td>\n        <td class=\"num\">{{ row.previous_days | int }}</td>\n        <td class=\"num\">{{ row.new_days | int }}</td>\n        <td style=\"color:#6b7280;\">{{ row.adjustment_reason or '&mdash;' }}</td>\n        <td style=\"font-size:7.5pt;\">{{ row.adjustment_invoice or '&mdash;' }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n  {% endif %}\n\n  <!-- COMPLETION AUDIT -->\n  {% if booking.event_status == 'Completed' %}\n  <div class=\"section-title\">Completion Audit</div>\n  <table class=\"info-table\" cellpadding=\"0\" cellspacing=\"0\">\n    <colgroup><col style=\"width:22%\" /><col style=\"width:28%\" /><col style=\"width:22%\" /><col style=\"width:28%\" /></colgroup>\n    <tr>\n      <td class=\"info-key\">Completed By</td><td class=\"info-val\">{{ booking.completed_by or '&mdash;' }}</td>\n      <td class=\"info-key\">Completed On</td><td class=\"info-val\">{{ booking.completed_on or '&mdash;' }}</td>\n    </tr>\n  </table>\n  {% endif %}\n\n  <!-- FINANCIAL SUMMARY -->\n  <div class=\"section-title\">Financial Summary</div>\n  <table class=\"balance-table\" cellpadding=\"0\" cellspacing=\"0\">\n    <tr>\n      <td class=\"b-label\">Hall Gross</td>\n      <td class=\"b-value\">&#x20a6;{{ \"{:,.2f}\".format(booking.total_amount | float) }}</td>\n    </tr>\n    <tr>\n      <td class=\"b-label\">Hall Discount</td>\n      <td class=\"b-value\">&minus; &#x20a6;{{ \"{:,.2f}\".format(hall_discount | float) }}</td>\n    </tr>\n    <tr>\n      <td class=\"b-label\">Net Total</td>\n      <td class=\"b-value\">&#x20a6;{{ \"{:,.2f}\".format(booking.net_total | float) }}</td>\n    </tr>\n    {% if booking.sales_invoice %}\n    <tr>\n      <td class=\"b-label\">Payment Status</td>\n      <td class=\"b-value\">{{ booking.payment_status or '&mdash;' }}</td>\n    </tr>\n    <tr>\n      <td class=\"b-label\">Paid Amount</td>\n      <td class=\"b-value\" style=\"color:#15803d;\">&#x20a6;{{ \"{:,.2f}\".format(booking.paid_amount | float) }}</td>\n    </tr>\n    {% endif %}\n    <tr class=\"total-row\">\n      <td>Outstanding Balance</td>\n      <td style=\"text-align:right;\">&#x20a6;{{ \"{:,.2f}\".format(booking.outstanding_amount | float) }}</td>\n    </tr>\n  </table>\n\n  {% if booking.docstatus == 0 %}\n  <div class=\"notice-box\">\n    <strong>Draft Document \u2014 Not Yet Confirmed.</strong> This is a preliminary booking draft and has not been submitted or confirmed. No invoice has been issued. All figures are subject to change.\n  </div>\n  {% endif %}\n\n  <!-- FOOTER -->\n  <hr class=\"footer-divider\" />\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n    <tr>\n      <td width=\"60%\" valign=\"bottom\">\n        <div class=\"footer-note\">\n          This confirmation is generated by the {{ company }} Property Management System.<br>\n          <strong style=\"color:#374151;\">Booking Reference: {{ booking.name }}</strong>\n        </div>\n      </td>\n      <td valign=\"bottom\" align=\"right\">\n        <div class=\"footer-company\">{{ company }}</div>\n        <div class=\"footer-date\">{{ generated_at }}</div>\n        <div class=\"sig-line\">Authorised Signature</div>\n      </td>\n    </tr>\n  </table>\n</div>\n</body>\n</html>",
 "format_data": "{\"report_type\": \"HTML\", \"html\": \"<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n<meta charset=\\\"UTF-8\\\" />\\n<style>\\n  @page { margin: 12mm 14mm 8mm 14mm; }\\n  * { box-sizing: border-box; margin: 0; padding: 0; }\\n  body { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #1a1a2e; background: #fff; }\\n  .page { max-width: 820px; margin: 0 auto; padding: 0; }\\n  .hotel-logo { max-height: 70px; max-width: 140px; }\\n  .logo-box { display: inline-block; width: 46px; height: 46px; background: #1a1a2e; color: #fff; font-size: 16pt; font-weight: 700; text-align: center; line-height: 46px; border-radius: 5px; }\\n  .hotel-name { font-size: 14pt; font-weight: 700; color: #1a1a2e; }\\n  .hotel-sub { font-size: 7.5pt; color: #6b7280; margin-top: 2px; line-height: 1.5; }\\n  .doc-title { font-size: 13pt; font-weight: 700; color: #1a1a2e; }\\n  .doc-subtitle { font-size: 7pt; color: #6b7280; text-transform: uppercase; letter-spacing: 0.8px; margin-top: 2px; }\\n  .doc-ref { font-size: 8pt; color: #6b7280; margin-top: 6px; line-height: 1.7; }\\n  .doc-ref strong { color: #374151; }\\n  .header-divider { border: none; border-top: 2px solid #1a1a2e; margin: 14px 0 16px; }\\n  .pill { display: inline-block; padding: 2px 9px; border-radius: 10px; font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; margin-right: 5px; border: 1px solid #d1d5db; background: #f9fafb; color: #374151; }\\n  .pills-row { margin-bottom: 14px; }\\n  .section-title { font-size: 7.5pt; font-weight: 700; color: #1a1a2e; text-transform: uppercase; letter-spacing: 0.6px; background: #f1f3f8; border-left: 3px solid #1a1a2e; border-bottom: 1px solid #d1d5db; padding: 5px 9px; margin-top: 14px; margin-bottom: 8px; }\\n  .info-table { width: 100%; border-collapse: collapse; margin-bottom: 4px; }\\n  .info-table td { padding: 4px 8px; font-size: 9pt; border-bottom: 1px solid #f1f5f9; vertical-align: middle; white-space: nowrap; }\\n  .info-table tr:last-child td { border-bottom: none; }\\n  .info-key { width: 22%; color: #1a1a2e; font-weight: 700; }\\n  .info-val { width: 28%; color: #1a1a2e; font-weight: 400; }\\n  .data-table { width: 100%; border-collapse: collapse; font-size: 8.5pt; margin-bottom: 4px; }\\n  .data-table thead tr { background: #f1f3f8; color: #1a1a2e; border-bottom: 2px solid #1a1a2e; }\\n  .data-table thead th { padding: 6px 9px; text-align: left; font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; }\\n  .data-table thead th.num { text-align: right; }\\n  .data-table tbody tr:nth-child(even) { background: #f9fafb; }\\n  .data-table tbody td { padding: 7px 9px; border-bottom: 1px solid #f1f5f9; color: #374151; }\\n  .data-table tbody td.num { text-align: right; }\\n  .data-table tfoot tr { border-top: 2px solid #1a1a2e; background: #f9fafb; }\\n  .data-table tfoot td { padding: 7px 9px; font-weight: 700; color: #1a1a2e; }\\n  .data-table tfoot td.num { text-align: right; }\\n  .balance-table { width: 55%; margin-left: 45%; border-collapse: collapse; margin-bottom: 4px; }\\n  .balance-table td { padding: 6px 10px; font-size: 9pt; border-bottom: 1px solid #f1f5f9; }\\n  .b-label { color: #6b7280; }\\n  .b-value { text-align: right; font-weight: 600; color: #1a1a2e; }\\n  .total-row td { background: #f1f3f8; color: #1a1a2e; font-weight: 700; font-size: 9.5pt; border-top: 2px solid #1a1a2e; border-bottom: 1px solid #d1d5db; }\\n  .notice-box { border: 1px solid #e5e7eb; border-radius: 4px; padding: 10px 14px; font-size: 8pt; color: #374151; margin-top: 8px; background: #fffbeb; }\\n  .footer-divider { border: none; border-top: 1px solid #e5e7eb; margin: 20px 0 12px; }\\n  .footer-note { font-size: 7pt; color: #9ca3af; line-height: 1.7; }\\n  .footer-company { font-size: 9pt; font-weight: 700; color: #1a1a2e; }\\n  .footer-date { font-size: 7pt; color: #9ca3af; margin-top: 2px; }\\n  .sig-line { margin-top: 16px; border-top: 1px solid #e5e7eb; padding-top: 5px; font-size: 7pt; color: #9ca3af; text-align: center; }\\n</style>\\n</head>\\n<body>\\n<div class=\\\"page\\\">\\n\\n  <!-- HEADER -->\\n  <table width=\\\"100%\\\" cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n    <tr>\\n      <td width=\\\"55%\\\" valign=\\\"top\\\">\\n        <table cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n          <tr>\\n            <td style=\\\"padding-right:10px;\\\" valign=\\\"middle\\\">\\n              {% if hotel_logo %}\\n                <img src=\\\"{{ hotel_logo }}\\\" alt=\\\"{{ company }}\\\" class=\\\"hotel-logo\\\" />\\n              {% else %}\\n                <div class=\\\"logo-box\\\">{{ (company or 'H')[:1] }}</div>\\n              {% endif %}\\n            </td>\\n            <td valign=\\\"middle\\\">\\n              <div class=\\\"hotel-name\\\">{{ company }}</div>\\n              <div class=\\\"hotel-sub\\\">\\n                {% if hotel_tagline %}{{ hotel_tagline }}<br>{% endif %}\\n                {% if hotel_address %}{{ hotel_address }}<br>{% endif %}\\n                {% if hotel_phone %}{{ hotel_phone }}{% if hotel_email %} &middot; {% endif %}{% endif %}\\n                {% if hotel_email %}{{ hotel_email }}{% endif %}\\n              </div>\\n            </td>\\n          </tr>\\n        </table>\\n      </td>\\n      <td valign=\\\"top\\\" align=\\\"right\\\">\\n        <div class=\\\"doc-title\\\">\\n          {% if booking.docstatus == 0 %}Hall Booking Draft\\n          {% elif booking.docstatus == 2 %}Hall Booking Cancelled\\n          {% else %}Hall Booking Confirmation{% endif %}\\n        </div>\\n        <div class=\\\"doc-subtitle\\\">Event Booking Receipt</div>\\n        <div class=\\\"doc-ref\\\">\\n          <strong>Ref:</strong> {{ booking.name }}<br>\\n          <strong>Generated:</strong> {{ generated_at }}\\n        </div>\\n      </td>\\n    </tr>\\n  </table>\\n  <hr class=\\\"header-divider\\\" />\\n\\n  <!-- STATUS PILLS -->\\n  <div class=\\\"pills-row\\\">\\n    <span class=\\\"pill\\\">{{ booking.event_status or 'Scheduled' }}</span>\\n    {% if booking.docstatus == 0 %}<span class=\\\"pill\\\">&#9679; Draft</span>{% endif %}\\n    {% if booking.event_type %}<span class=\\\"pill\\\">{{ booking.event_type }}</span>{% endif %}\\n  </div>\\n\\n  <!-- BOOKING DETAILS -->\\n  <div class=\\\"section-title\\\">Booking Details</div>\\n  <table class=\\\"info-table\\\" cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n    <colgroup><col style=\\\"width:22%\\\" /><col style=\\\"width:28%\\\" /><col style=\\\"width:22%\\\" /><col style=\\\"width:28%\\\" /></colgroup>\\n    <tr>\\n      <td class=\\\"info-key\\\">Customer</td><td class=\\\"info-val\\\">{{ booking.customer_name or '&mdash;' }}</td>\\n      <td class=\\\"info-key\\\">Mobile</td><td class=\\\"info-val\\\">{{ booking.mobile_number or '&mdash;' }}</td>\\n    </tr>\\n    <tr>\\n      <td class=\\\"info-key\\\">Hall</td><td class=\\\"info-val\\\">{{ booking.hall or '&mdash;' }}</td>\\n      <td class=\\\"info-key\\\">Event Type</td><td class=\\\"info-val\\\">{{ booking.event_type or '&mdash;' }}</td>\\n    </tr>\\n    <tr>\\n      <td class=\\\"info-key\\\">Start</td><td class=\\\"info-val\\\">{{ booking.start_datetime }}</td>\\n      <td class=\\\"info-key\\\">End</td><td class=\\\"info-val\\\">{{ booking.end_datetime }}</td>\\n    </tr>\\n    <tr>\\n      <td class=\\\"info-key\\\">Duration</td><td class=\\\"info-val\\\">{{ booking.total_days | int }} day(s)</td>\\n      <td class=\\\"info-key\\\">Rate / Day</td><td class=\\\"info-val\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(booking.rate | float) }}</td>\\n    </tr>\\n    {% if booking.sales_invoice %}\\n    <tr>\\n      <td class=\\\"info-key\\\">Sales Invoice</td><td class=\\\"info-val\\\" colspan=\\\"3\\\">{{ booking.sales_invoice }}</td>\\n    </tr>\\n    {% endif %}\\n  </table>\\n\\n  <!-- HALL CHARGES -->\\n  {% set hall_discount = 0 %}\\n  {% if booking.discount_type == \\\"Percentage\\\" %}\\n    {% set hall_discount = (booking.total_amount or 0) * ((booking.discount_amount or 0) / 100) %}\\n  {% else %}\\n    {% set hall_discount = booking.discount_amount or 0 %}\\n  {% endif %}\\n\\n  <div class=\\\"section-title\\\">Hall Charges</div>\\n  <table class=\\\"data-table\\\" cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n    <thead>\\n      <tr>\\n        <th>Description</th><th class=\\\"num\\\">Days</th>\\n        <th class=\\\"num\\\">Rate</th><th class=\\\"num\\\">Gross</th>\\n        <th class=\\\"num\\\">Discount</th><th class=\\\"num\\\">Net</th>\\n      </tr>\\n    </thead>\\n    <tbody>\\n      <tr>\\n        <td style=\\\"font-weight:600;\\\">{{ booking.hall or 'Hall Booking' }}</td>\\n        <td class=\\\"num\\\">{{ booking.total_days | int }}</td>\\n        <td class=\\\"num\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(booking.rate | float) }}</td>\\n        <td class=\\\"num\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(booking.total_amount | float) }}</td>\\n        <td class=\\\"num\\\">\\n          &#x20a6;{{ \\\"{:,.2f}\\\".format(hall_discount | float) }}\\n          {% if booking.discount_amount %}<br><span style=\\\"font-size:7pt;color:#6b7280;\\\">{{ booking.discount_type }}: {{ booking.discount_amount }}{% if booking.discount_type == \\\"Percentage\\\" %}%{% endif %}</span>{% endif %}\\n        </td>\\n        <td class=\\\"num\\\" style=\\\"font-weight:600;\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format((booking.total_amount | float) - (hall_discount | float)) }}</td>\\n      </tr>\\n    </tbody>\\n  </table>\\n\\n  <!-- ADDITIONAL SERVICES -->\\n  {% if additional_billings %}\\n  <div class=\\\"section-title\\\">Additional Services</div>\\n  <table class=\\\"data-table\\\" cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n    <thead>\\n      <tr>\\n        <th>Service</th><th class=\\\"num\\\">Qty</th><th class=\\\"num\\\">Rate</th>\\n        <th>Discount Type</th><th class=\\\"num\\\">Discount</th><th class=\\\"num\\\">Amount</th>\\n      </tr>\\n    </thead>\\n    <tbody>\\n      {% for row in additional_billings %}\\n      <tr>\\n        <td>{{ row.service or '&mdash;' }}</td>\\n        <td class=\\\"num\\\">{{ row.qty or 0 }}</td>\\n        <td class=\\\"num\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(row.rate | float) }}</td>\\n        <td style=\\\"color:#6b7280;\\\">{{ row.discount_type or '&mdash;' }}</td>\\n        <td class=\\\"num\\\">{% if row.discount_type == \\\"Percentage\\\" %}{{ row.discount_amount }}%{% else %}&#x20a6;{{ \\\"{:,.2f}\\\".format(row.discount_amount | float) }}{% endif %}</td>\\n        <td class=\\\"num\\\" style=\\\"font-weight:600;\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(row.amount | float) }}</td>\\n      </tr>\\n      {% endfor %}\\n    </tbody>\\n  </table>\\n  {% endif %}\\n\\n  <!-- ADJUSTMENT HISTORY -->\\n  {% if adjustment_history %}\\n  <div class=\\\"section-title\\\">Adjustment History</div>\\n  <table class=\\\"data-table\\\" cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n    <thead>\\n      <tr>\\n        <th>Previous Period</th><th>New Period</th>\\n        <th class=\\\"num\\\">Prev Days</th><th class=\\\"num\\\">New Days</th>\\n        <th>Reason</th><th>Invoice</th>\\n      </tr>\\n    </thead>\\n    <tbody>\\n      {% for row in adjustment_history %}\\n      <tr>\\n        <td style=\\\"font-size:7.5pt;color:#6b7280;\\\">{{ row.previous_start }} &rarr; {{ row.previous_end }}</td>\\n        <td style=\\\"font-size:7.5pt;color:#6b7280;\\\">{{ row.new_start }} &rarr; {{ row.new_end }}</td>\\n        <td class=\\\"num\\\">{{ row.previous_days | int }}</td>\\n        <td class=\\\"num\\\">{{ row.new_days | int }}</td>\\n        <td style=\\\"color:#6b7280;\\\">{{ row.adjustment_reason or '&mdash;' }}</td>\\n        <td style=\\\"font-size:7.5pt;\\\">{{ row.adjustment_invoice or '&mdash;' }}</td>\\n      </tr>\\n      {% endfor %}\\n    </tbody>\\n  </table>\\n  {% endif %}\\n\\n  <!-- COMPLETION AUDIT -->\\n  {% if booking.event_status == 'Completed' %}\\n  <div class=\\\"section-title\\\">Completion Audit</div>\\n  <table class=\\\"info-table\\\" cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n    <colgroup><col style=\\\"width:22%\\\" /><col style=\\\"width:28%\\\" /><col style=\\\"width:22%\\\" /><col style=\\\"width:28%\\\" /></colgroup>\\n    <tr>\\n      <td class=\\\"info-key\\\">Completed By</td><td class=\\\"info-val\\\">{{ booking.completed_by or '&mdash;' }}</td>\\n      <td class=\\\"info-key\\\">Completed On</td><td class=\\\"info-val\\\">{{ booking.completed_on or '&mdash;' }}</td>\\n    </tr>\\n  </table>\\n  {% endif %}\\n\\n  <!-- FINANCIAL SUMMARY -->\\n  <div class=\\\"section-title\\\">Financial Summary</div>\\n  <table class=\\\"balance-table\\\" cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n    <tr>\\n      <td class=\\\"b-label\\\">Hall Gross</td>\\n      <td class=\\\"b-value\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(booking.total_amount | float) }}</td>\\n    </tr>\\n    <tr>\\n      <td class=\\\"b-label\\\">Hall Discount</td>\\n      <td class=\\\"b-value\\\">&minus; &#x20a6;{{ \\\"{:,.2f}\\\".format(hall_discount | float) }}</td>\\n    </tr>\\n    <tr>\\n      <td class=\\\"b-label\\\">Net Total</td>\\n      <td class=\\\"b-value\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(booking.net_total | float) }}</td>\\n    </tr>\\n    {% if booking.sales_invoice %}\\n    <tr>\\n      <td class=\\\"b-label\\\">Payment Status</td>\\n      <td class=\\\"b-value\\\">{{ booking.payment_status or '&mdash;' }}</td>\\n    </tr>\\n    <tr>\\n      <td class=\\\"b-label\\\">Paid Amount</td>\\n      <td class=\\\"b-value\\\" style=\\\"color:#15803d;\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(booking.paid_amount | float) }}</td>\\n    </tr>\\n    {% endif %}\\n    <tr class=\\\"total-row\\\">\\n      <td>Outstanding Balance</td>\\n      <td style=\\\"text-align:right;\\\">&#x20a6;{{ \\\"{:,.2f}\\\".format(booking.outstanding_amount | float) }}</td>\\n    </tr>\\n  </table>\\n\\n  {% if booking.docstatus == 0 %}\\n  <div class=\\\"notice-box\\\">\\n    <strong>Draft Document \\u2014 Not Yet Confirmed.</strong> This is a preliminary booking draft and has not been submitted or confirmed. No invoice has been issued. All figures are subject to change.\\n  </div>\\n  {% endif %}\\n\\n  <!-- FOOTER -->\\n  <hr class=\\\"footer-divider\\\" />\\n  <table width=\\\"100%\\\" cellpadding=\\\"0\\\" cellspacing=\\\"0\\\">\\n    <tr>\\n      <td width=\\\"60%\\\" valign=\\\"bottom\\\">\\n        <div class=\\\"footer-note\\\">\\n          This confirmation is generated by the {{ company }} Property Management System.<br>\\n          <strong style=\\\"color:#374151;\\\">Booking Reference: {{ booking.name }}</strong>\\n        </div>\\n      </td>\\n      <td valign=\\\"bottom\\\" align=\\\"right\\\">\\n        <div class=\\\"footer-company\\\">{{ company }}</div>\\n        <div class=\\\"footer-date\\\">{{ generated_at }}</div>\\n        <div class=\\\"sig-line\\\">Authorised Signature</div>\\n      </td>\\n    </tr>\\n  </table>\\n</div>\\n</body>\\n</html>\"}"
}