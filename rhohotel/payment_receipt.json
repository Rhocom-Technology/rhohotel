    "format_data": "{\"report_type\":\"HTML\",\"html\":\"{% set guest = frappe.get_doc(\\\"Hotel Guest\\\", doc.get_guest()) %}\\n<div class=\\\"payment-receipt\\\" style=\\\"font-family: sans-serif; max-width: 800px; margin: auto; padding: 20px; border: 1px solid #eee;\\\">\\n    <div style=\\\"text-align: center; margin-bottom: 20px;\\\">\\n        <h2>{{ frappe.get_single_value(\\\"Global Defaults\\\", \\\"company_name\\\") }}</h2>\\n        <p>Payment Receipt</p>\\n    </div>\\n    <hr>\\n    <table style=\\\"width: 100%; margin-bottom: 20px;\\\">\\n        <tr>\\n            <td style=\\\"width: 50%;\\\">\\n                <strong>Billed To:</strong><br>\\n                {{ guest.hotel_guest_name }}<br>\\n                {{ guest.email }}<br>\\n                {{ guest.phone_number }}\\n            </td>\\n            <td style=\\\"width: 50%; text-align: right;\\\">\\n                <strong>Receipt No:</strong> {{ doc.name }}<br>\\n                <strong>Date:</strong> {{ frappe.utils.format_date(doc.posting_date) }}<br>\\n                <strong>Payment Reference:</strong> {{ doc.payment_reference }}\\n            </td>\\n        </tr>\\n    </table>\\n\\n    <table style=\\\"width: 100%; border-collapse: collapse;\\\">\\n        <thead>\\n            <tr style=\\\"background-color: #f2f2f2;\\\">\\n                <th style=\\\"padding: 8px; border: 1px solid #ddd; text-align: left;\\\">Invoice #</th>\\n                <th style=\\\"padding: 8px; border: 1px solid #ddd; text-align: right;\\\">Amount Paid</th>\\n            </tr>\\n        </thead>\\n        <tbody>\\n            {% for item in doc.get_paid_invoices() %}\\n            <tr>\\n                <td style=\\\"padding: 8px; border: 1px solid #ddd;\\\">{{ item.invoice_number }}</td>\\n                <td style=\\\"padding: 8px; border: 1px solid #ddd; text-align: right;\\\">{{ frappe.utils.format_currency(item.amount, doc.currency) }}</td>\\n            </tr>\\n            {% endfor %}\\n        </tbody>\\n        <tfoot>\\n            <tr>\\n                <td style=\\\"padding: 8px; border: 1px solid #ddd; text-align: right;\\\"><strong>Total Paid</strong></td>\\n                <td style=\\\"padding: 8px; border: 1px solid #ddd; text-align: right;\\\"><strong>{{ frappe.utils.format_currency(doc.total_amount, doc.currency) }}</strong></td>\\n            </tr>\\n        </tfoot>\\n    </table>\\n\\n    <div style=\\\"text-align: center; margin-top: 30px; font-size: 12px; color: #777;\\\">\\n        <p>Thank you for your payment!</p>\\n    </div>\\n</div>\"}",
